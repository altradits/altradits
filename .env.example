# ── Database (local Docker: make dev-db) ─────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/altradits?sslmode=disable

# ── Redis (local Docker: make dev-db) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (required — change in production) ─────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ── Admin account (optional) ─────────────────────────────────────────────────
# If set, this account is created (or promoted to admin) on startup. Leave
# blank to skip. The password is hashed before storage, just like any other
# user — never stored in plaintext.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Wallet: BTC/KES exchange rate (optional — sensible defaults apply) ───────
EXCHANGE_RATE_API_URL=https://api.coingecko.com/api/v3
EXCHANGE_RATE_CACHE_TTL=300

# ── Wallet: Lightning (optional — falls back to mock provider) ───────────────
# Set LND_REST_HOST to connect to a real LND node via its REST API. If unset
# or unreachable, the wallet uses a mock Lightning provider for local dev.
LND_REST_HOST=
# Provide the macaroon as hex, or point to a macaroon file (e.g. invoice.macaroon).
LND_MACAROON_HEX=
LND_MACAROON_PATH=
# TLS verification for the LND node. Prefer pointing at LND's tls.cert; use
# LND_TLS_INSECURE_SKIP_VERIFY=true only for local/dev nodes (e.g. Polar).
LND_TLS_CERT_PATH=
LND_TLS_INSECURE_SKIP_VERIFY=
